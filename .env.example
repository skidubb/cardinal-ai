# ============================================================================
# CE-AGENTS — Consolidated Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# Only ANTHROPIC_API_KEY is strictly required. All other keys are optional
# and services degrade gracefully when not configured.
# ============================================================================

# === LLM API Keys (Required) ===
# Anthropic API key — used by all 3 projects (Agent Builder, Orchestration, Evals)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === LLM API Keys (Optional) ===
# OpenAI — used by Agent Builder (image gen) and Evals (GPT-4 judge backend)
OPENAI_API_KEY=sk-proj-your-key-here
# Google — used by Agent Builder and Evals (Gemini judge backend)
GOOGLE_API_KEY=your-google-api-key-here
# xAI (Grok) — used by Agent Builder
XAI_API_KEY=xai-your-key-here

# === Observability ===
# Langfuse — used by Orchestration for protocol tracing. Cloud or self-hosted.
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
# Standardized name: use LANGFUSE_BASE_URL (not LANGFUSE_HOST)
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# === Storage ===
# Pinecone — used by Agent Builder (knowledge base, memory) and Orchestration
PINECONE_API_KEY=your-pinecone-api-key-here
# DuckDB — used by Agent Builder for non-vector local storage
DUCKDB_PATH=./data/agent_memory.duckdb

# === Docker / Postgres ===
# Used by docker-compose.yml for Postgres and Metabase services.
# Also used by Orchestration for run persistence (via ce-db).
POSTGRES_USER=ce
POSTGRES_PASSWORD=ce_local
POSTGRES_DB=ce_platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === Search & Integration ===
# Brave Search — used by Agent Builder (web search tool)
BRAVE_API_KEY=your-brave-api-key-here
# Notion — used by Agent Builder (Notion API integration)
# Standardized name: use NOTION_API_KEY (not NOTION_TOKEN)
NOTION_API_KEY=secret_your-notion-key-here

# === Government Data APIs (Optional) ===
# Used by Agent Builder for market research tools
# Data.gov
DATA_GOV_API_KEY=your-data-gov-key-here
# SEC EDGAR — public company filings
SEC_EDGAR_API_KEY=your-sec-edgar-key-here
# US Census Bureau — market sizing data
US_CENSUS_API_KEY=your-census-key-here
# Bureau of Labor Statistics — labor market data
US_BLS_API_KEY=your-bls-key-here

# === Application Config (Optional) ===
# AGENT_BACKEND=sdk          # Agent Builder: 'sdk' or 'legacy' (default: legacy)
# AGENT_MODE=production      # Orchestration: 'production' or 'research' (default: production)
# MEMORY_ENABLED=true        # Agent Builder: enable/disable Pinecone memory
# Max USD per protocol run before warning (warn-only, does not halt)
PROTOCOL_COST_CEILING=5.00

# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Workspace (for all agents)
GOOGLE_CREDENTIALS_PATH=./credentials/google-credentials.json

# GitHub (for CTO)
GITHUB_TOKEN=your_github_personal_access_token

# QuickBooks (for CFO)
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret
QUICKBOOKS_REFRESH_TOKEN=your_quickbooks_refresh_token
QUICKBOOKS_REALM_ID=your_quickbooks_realm_id

# OpenAI (Image Generation — CMO/CPO)
OPENAI_API_KEY=your_openai_api_key
# Google Gemini (Image Generation — CMO/CPO)
GEMINI_API_KEY=your_gemini_api_key

# Pinecone (Knowledge Base - all agents)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_HOST=your_pinecone_index_host
PINECONE_LEARNING_INDEX_HOST=your_pinecone_learning_index_host

# Brave Search (Web Search — all agents)
BRAVE_API_KEY=your_brave_search_api_key

# Notion (COO primary, all agents read)
NOTION_API_KEY=your_notion_integration_token

# Storage
DUCKDB_PATH=./data/agent_memory.duckdb

# Memory (enabled by default — Pinecone-backed via integrated inference)
MEMORY_ENABLED=true

# Session Configuration
SESSION_DIR=./sessions
REPORTS_DIR=./reports

# Agent Backend (legacy = BaseAgent subclasses, sdk = Claude Agent SDK with MCP tools)
AGENT_BACKEND=legacy

# Default Model (can be overridden per agent)
DEFAULT_MODEL=claude-opus-4-6
